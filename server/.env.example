# ─── Required ─────────────────────────────────────────────────────────────────
SESSION_SECRET=change-me-to-a-random-32-char-string-minimum

# ─── Database: Option A — Local PostgreSQL (Docker default) ──────────────────
# Used when DATABASE_URL is not set.
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DATABASE=servervault

# ─── Database: Option B — Supabase ───────────────────────────────────────────
# Set this to override POSTGRES_* above. SSL is enabled automatically.
# Get your connection string from: Supabase Dashboard → Project Settings → Database
# Use "Session mode" (port 5432) — NOT Transaction mode (port 6543),
# because the app uses prepared statements and persistent sessions.
#
# DATABASE_URL=postgresql://postgres.[project-ref]:[db-password]@aws-0-[region].pooler.supabase.com:5432/postgres

# ─── App ──────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=8080
# HTTP bind (default 0.0.0.0 — all interfaces; use 127.0.0.1 to restrict to localhost)
# HOST=0.0.0.0
CLIENT_URL=http://localhost:8080
COOKIE_SECURE=false
